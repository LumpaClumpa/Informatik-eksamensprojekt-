#include <ArduinoJson.h> // For data to json format

// WiFi stuff
#include <WiFi.h>
#include <HTTPClient.h>
const char* ssid = "INSERT_NAME"; // WiFi name
const char* password = "INSERT_PASSWORD"; // WiFi password
const char* serverName = "http://INSERT_IP:5000/items"; // IP

// Sensor stuff
#include "DHT.h"
#define DHTPIN 5
#define DHTTYPE DHT22   // DHT 22  (AM2302)
DHT dht(DHTPIN, DHTTYPE);

void setup() {
  Serial.begin(9600);
  // WiFi setup
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(1000);
    Serial.println("Connecting...");
  }
  Serial.println("Connected :)");

  dht.begin();
}

void loop() {
  float h = dht.readHumidity(); // Humidity
  float t = dht.readTemperature(); // Temperature

  if (isnan(h) || isnan(t)) {
    Serial.println("Failed to read");
  }
  
  Serial.print("Temp: "); // debug
  Serial.println(t);
  Serial.print("Humidity: ");
  Serial.println(h);

  if (WiFi.status() == WL_CONNECTED) {
    HTTPClient http;

    http.begin(serverName);
    http.addHeader("Content-Type", "application/json");

    StaticJsonDocument<256> doc;

    JsonArray readings = doc.createNestedArray("sensor_readings");

    // Temperature object
    JsonObject tempObj = readings.createNestedObject();
    tempObj["sensor_id"] = 1;
    tempObj["recorded_at"] = "2026-05-03";
    tempObj["is_active"] = "yes";
    tempObj["unit"] = "C";
    tempObj["reading"] = 100; // fake data, replace with t to get live value

    // Humidity object
    JsonObject humObj = readings.createNestedObject();
    humObj["sensor_id"] = 2;
    humObj["recorded_at"] = "2026-05-03";
    humObj["is_active"] = "yes";
    humObj["unit"] = "%";
    humObj["reading"] = 50; // fake data, replace with h to get live value

    // Convert to string
    String json;
    serializeJson(doc, json);
    Serial.println(json); // debug

    int httpResponseCode = http.POST(json);

    Serial.print("HTTP Response: ");
    Serial.println(httpResponseCode);

    http.end();
  }
  delay(1000);
}
